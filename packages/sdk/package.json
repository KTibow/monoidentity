{
  "name": "monoidentity",
  "version": "0.31.2",
  "license": "ISC",
  "repository": "KTibow/monoidentity",
  "author": {
    "name": "KTibow"
  },
  "homepage": "https://github.com/KTibow/monoidentity",
  "funding": "https://github.com/sponsors/KTibow",
  "scripts": {
    "dev": "vite dev",
    "build": "pnpm run prepack",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css",
    "**/+receive-callback.js"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/+index.d.ts",
      "svelte": "./dist/+index.js"
    },
    "./receive-callback": {
      "types": "./dist/+receive-callback.d.ts",
      "import": "./dist/+receive-callback.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "base36-esm": "^0.1.0",
    "devalue": "^5.6.3",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "publint": "^0.3.17",
    "svelte": "^5.53.2",
    "svelte-check": "^4.4.3",
    "vite": "8.0.0-beta.15"
  },
  "keywords": [
    "svelte"
  ]
}
