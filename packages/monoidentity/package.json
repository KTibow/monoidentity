{
  "name": "monoidentity",
  "version": "0.31.8",
  "license": "ISC",
  "repository": "KTibow/monoidentity",
  "author": {
    "name": "KTibow"
  },
  "homepage": "https://github.com/KTibow/monoidentity",
  "funding": "https://github.com/sponsors/KTibow",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/receive-callback.js"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./receive-callback": {
      "types": "./dist/receive-callback.d.ts",
      "import": "./dist/receive-callback.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "base36-esm": "^0.1.0",
    "devalue": "^5.6.3",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "tsdown": "^0.20.3"
  },
  "keywords": [
    "svelte"
  ]
}
