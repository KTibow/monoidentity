{
  "name": "monoidentity-workspace",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter ./packages/hub dev",
    "build": "pnpm run build:sdk && pnpm run build:hub && pnpm run build:firebase-functions",
    "build:hub": "pnpm --filter ./packages/hub build",
    "build:sdk": "pnpm --filter ./packages/sdk build",
    "build:verification": "pnpm --filter ./packages/monoidentity-verification build",
    "build:sync": "pnpm --filter ./packages/monoidentity-sync build",
    "build:firebase-functions": "pnpm --filter ./packages/firebase-functions build",
    "check": "pnpm -r --if-present check",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "knip": "knip"
  },
  "devDependencies": {
    "knip": "^5.85.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
